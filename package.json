{
  "name": "jp-badminton-tournament",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently -n FRONTEND,BACKEND -c auto \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:backend": "npm --prefix backend run build",
    "build:all": "npm run build && npm run build:backend",
    "setup:backend": "npm --prefix backend install"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.7"
  }
}