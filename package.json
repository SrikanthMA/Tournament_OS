{
  "name": "jp-badminton-tournament",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently -n FRONTEND,BACKEND -c auto \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:backend": "npm --prefix backend run build",
    "build:all": "npm run build && npm run build:backend",
    "setup:backend": "npm --prefix backend install"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "^9.2.0"
  }
}
